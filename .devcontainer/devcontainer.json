{
  "name": "Claude Code Workshop",
  "image": "ghcr.io/nakuls08/cc-workshop-devcontainer:latest",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "updateContentCommand": "npm ci --prefix templates/portfolio && npm ci --prefix templates/landing",
  "waitFor": "updateContentCommand",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Website preview",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
